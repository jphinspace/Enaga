---
# Enaga project clang-tidy configuration.
#
# Naming conventions follow the Google C++ Style Guide:
#   https://google.github.io/styleguide/cppguide.html
#
# Enabled check families:
#   readability-*        — naming, clarity, and readability improvements
#   modernize-*          — update to modern C++ idioms
#   cppcoreguidelines-*  — C++ Core Guidelines enforcement
#
# JUCE macro-generated code is excluded via HeaderFilterRegex so that
# warnings originating inside JUCE's own headers are suppressed.

Checks: >
  readability-*,
  modernize-*,
  cppcoreguidelines-*,
  -modernize-use-trailing-return-type,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-type-vararg,
  -cppcoreguidelines-special-member-functions,
  -readability-identifier-length

# Only report warnings for headers under Source/ (not JUCE internals).
HeaderFilterRegex: "Source/.*"

WarningsAsErrors: ""

CheckOptions:
  # Google style: types are CamelCase
  - key:   readability-identifier-naming.ClassCase
    value: CamelCase
  - key:   readability-identifier-naming.StructCase
    value: CamelCase
  - key:   readability-identifier-naming.EnumCase
    value: CamelCase
  # Google style: functions are CamelCase (UpperCamelCase)
  - key:   readability-identifier-naming.FunctionCase
    value: CamelCase
  - key:   readability-identifier-naming.MethodCase
    value: CamelCase
  # Google style: non-static data members are snake_case with trailing _
  - key:   readability-identifier-naming.MemberCase
    value: lower_case
  - key:   readability-identifier-naming.MemberSuffix
    value: _
  # Google style: local variables and parameters are snake_case
  - key:   readability-identifier-naming.VariableCase
    value: lower_case
  - key:   readability-identifier-naming.ParameterCase
    value: lower_case
  # Google style: constants (including constexpr) are kCamelCase
  - key:   readability-identifier-naming.ConstantCase
    value: CamelCase
  - key:   readability-identifier-naming.ConstantPrefix
    value: k
  - key:   readability-identifier-naming.StaticConstantCase
    value: CamelCase
  - key:   readability-identifier-naming.StaticConstantPrefix
    value: k
  # Google style: enum values are kCamelCase
  - key:   readability-identifier-naming.EnumConstantCase
    value: CamelCase
  - key:   readability-identifier-naming.EnumConstantPrefix
    value: k
  - key:   modernize-use-default-member-init.UseAssignment
    value: "1"
