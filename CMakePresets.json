{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 22, "patch": 0 },
    "configurePresets": [
        {
            "name":        "base",
            "hidden":      true,
            "binaryDir":   "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":             "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },

        {
            "name":        "base-release",
            "hidden":      true,
            "binaryDir":   "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":             "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },

        {
            "name":        "linux",
            "displayName": "Linux – Ninja – Debug",
            "description": "Desktop Linux build using the Ninja generator.",
            "inherits":    "base",
            "generator":   "Ninja",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Linux"
            }
        },

        {
            "name":        "macos",
            "displayName": "macOS – Xcode – Debug",
            "description": "Desktop macOS build using the Xcode generator.",
            "inherits":    "base",
            "generator":   "Xcode",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Darwin"
            }
        },

        {
            "name":        "windows",
            "displayName": "Windows – Visual Studio 2022 – Debug",
            "description": "Desktop Windows build using Visual Studio 2022.",
            "inherits":    "base",
            "generator":   "Visual Studio 17 2022",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Windows"
            }
        },

        {
            "name":        "ios",
            "displayName": "iOS – Xcode – Debug",
            "description": "iOS device / simulator build.  Must be configured on macOS.",
            "inherits":    "base",
            "generator":   "Xcode",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS"
            },
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Darwin"
            }
        },

        {
            "name":        "android",
            "displayName": "Android – Ninja – Debug",
            "description": "Android ARM64 build.  Requires Android NDK; set ANDROID_NDK env var.",
            "inherits":    "base",
            "generator":   "Ninja",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME":       "Android",
                "CMAKE_ANDROID_ARCH_ABI":  "arm64-v8a",
                "CMAKE_ANDROID_STL_TYPE":  "c++_shared",
                "ANDROID_PLATFORM":        "android-24"
            }
        },

        {
            "name":        "linux-release",
            "displayName": "Linux – Ninja – Release",
            "description": "Desktop Linux release build using the Ninja generator.",
            "inherits":    "base-release",
            "generator":   "Ninja",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Linux"
            }
        },

        {
            "name":        "macos-release",
            "displayName": "macOS – Xcode – Release",
            "description": "Desktop macOS release build using the Xcode generator.",
            "inherits":    "base-release",
            "generator":   "Xcode",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Darwin"
            }
        },

        {
            "name":        "windows-release",
            "displayName": "Windows – Visual Studio 2022 – Release",
            "description": "Desktop Windows release build using Visual Studio 2022.",
            "inherits":    "base-release",
            "generator":   "Visual Studio 17 2022",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Windows"
            }
        },

        {
            "name":        "ios-release",
            "displayName": "iOS – Xcode – Release",
            "description": "iOS device / simulator release build.  Must be configured on macOS.",
            "inherits":    "base-release",
            "generator":   "Xcode",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS"
            },
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Darwin"
            }
        },

        {
            "name":        "android-release",
            "displayName": "Android – Ninja – Release",
            "description": "Android ARM64 release build.  Requires Android NDK; set ANDROID_NDK env var.",
            "inherits":    "base-release",
            "generator":   "Ninja",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME":       "Android",
                "CMAKE_ANDROID_ARCH_ABI":  "arm64-v8a",
                "CMAKE_ANDROID_STL_TYPE":  "c++_shared",
                "ANDROID_PLATFORM":        "android-24"
            }
        }
    ],

    "buildPresets": [
        { "name": "linux",            "configurePreset": "linux"            },
        { "name": "macos",            "configurePreset": "macos"            },
        { "name": "windows",          "configurePreset": "windows"          },
        { "name": "ios",              "configurePreset": "ios"              },
        { "name": "android",          "configurePreset": "android"          },
        { "name": "linux-release",    "configurePreset": "linux-release"    },
        { "name": "macos-release",    "configurePreset": "macos-release"    },
        { "name": "windows-release",  "configurePreset": "windows-release"  },
        { "name": "ios-release",      "configurePreset": "ios-release"      },
        { "name": "android-release",  "configurePreset": "android-release"  }
    ]
}
