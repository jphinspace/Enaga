{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 22, "patch": 0 },
    "configurePresets": [
        {
            "name":        "base",
            "hidden":      true,
            "binaryDir":   "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },

        {
            "name":        "linux",
            "displayName": "Linux – Ninja – Debug",
            "description": "Desktop Linux build using the Ninja generator.",
            "inherits":    "base",
            "generator":   "Ninja",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Linux"
            }
        },

        {
            "name":        "macos",
            "displayName": "macOS – Xcode – Debug",
            "description": "Desktop macOS build using the Xcode generator.",
            "inherits":    "base",
            "generator":   "Xcode",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Darwin"
            }
        },

        {
            "name":        "windows",
            "displayName": "Windows – Visual Studio 2022 – Debug",
            "description": "Desktop Windows build using Visual Studio 2022.",
            "inherits":    "base",
            "generator":   "Visual Studio 17 2022",
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Windows"
            }
        },

        {
            "name":        "ios",
            "displayName": "iOS – Xcode – Debug",
            "description": "iOS device / simulator build.  Must be configured on macOS.",
            "inherits":    "base",
            "generator":   "Xcode",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS"
            },
            "condition": {
                "type": "equals",
                "lhs":  "${hostSystemName}",
                "rhs":  "Darwin"
            }
        },

        {
            "name":        "android",
            "displayName": "Android – Ninja – Debug",
            "description": "Android ARM64 build.  Requires Android NDK; set ANDROID_NDK env var.",
            "inherits":    "base",
            "generator":   "Ninja",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME":       "Android",
                "CMAKE_ANDROID_ARCH_ABI":  "arm64-v8a",
                "CMAKE_ANDROID_STL_TYPE":  "c++_shared",
                "ANDROID_PLATFORM":        "android-24"
            }
        }
    ],

    "buildPresets": [
        { "name": "linux",   "configurePreset": "linux"   },
        { "name": "macos",   "configurePreset": "macos"   },
        { "name": "windows", "configurePreset": "windows" },
        { "name": "ios",     "configurePreset": "ios"     },
        { "name": "android", "configurePreset": "android" }
    ]
}
